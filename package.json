{
  "name": "jasprtailwindclient",
  "version": "1.0.0",
  "description": "A new Jaspr project",
  "main": "main.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "concurrently \"jaspr serve\" \"npm run dev:css\"",
    "dev:css": "npx tailwindcss -i ./web/styles.tw.css -o ./web/output.css --watch",
    "build:css": "npx tailwindcss -i ./web/styles.tw.css -o ./web/output.css --minify"
  },
  "keywords": [],
