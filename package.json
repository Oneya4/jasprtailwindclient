  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2"
  }
}
